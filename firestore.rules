rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "dtasmimhd11@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.role in ['landlord', 'tenant'] &&
             data.name is string && data.name.size() > 0;
    }

    function isValidProperty(data) {
      return data.ownerId is string && data.ownerId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.location is string && data.location.size() > 0 &&
             data.status in ['available', 'rented'];
    }

    function isValidChat(data) {
      return data.participants is list && data.participants.size() == 2 &&
             request.auth.uid in data.participants;
    }

    function isValidMessage(data) {
      return data.senderId is string && data.senderId == request.auth.uid &&
             data.text is string && data.text.size() > 0;
    }

    function isValidVisit(data) {
      return data.propertyId is string &&
             data.tenantId is string &&
             data.landlordId is string &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidProperty(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidProperty(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /visits/{visitId} {
      allow read: if isAuthenticated() && 
                  (request.auth.uid == resource.data.tenantId || 
                   request.auth.uid == resource.data.landlordId || 
                   isAdmin());
      allow create: if isAuthenticated() && 
                    request.resource.data.tenantId == request.auth.uid &&
                    isValidVisit(request.resource.data);
      allow update: if isAuthenticated() && 
                    (request.auth.uid == resource.data.tenantId || 
                     request.auth.uid == resource.data.landlordId || 
                     isAdmin()) &&
                    isValidVisit(request.resource.data);
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      }
    }

    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isOwner(userId);
    }
    
    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
