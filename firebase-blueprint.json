{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["landlord", "tenant"] },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "searchHistory": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "role"]
    },
    "Property": {
      "title": "Property",
      "description": "Rental property listing",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "location": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string" },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "isFeatured": { "type": "boolean" },
        "status": { "type": "string", "enum": ["available", "rented"] },
        "views": { "type": "number" },
        "clicks": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "title", "price", "location"]
    },
    "Visit": {
      "title": "Visit",
      "description": "Scheduled property visit",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "tenantId": { "type": "string" },
        "landlordId": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] }
      },
      "required": ["propertyId", "tenantId", "landlordId", "scheduledAt"]
    }
  },
  "firestore": {
    "users/{userId}": { "schema": "User", "description": "User profiles" },
    "properties/{propertyId}": { "schema": "Property", "description": "Property listings" },
    "chats/{chatId}": { "schema": "Chat", "description": "Chat sessions" },
    "chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Messages within a chat" },
    "users/{userId}/favorites/{favoriteId}": { "schema": "Favorite", "description": "User favorites" },
    "visits/{visitId}": { "schema": "Visit", "description": "Scheduled visits" }
  }
}
