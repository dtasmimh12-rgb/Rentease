{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["landlord", "tenant"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Property": {
      "title": "Property",
      "description": "Rental property listing",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "location": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "title", "price", "location"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Chat session between landlord and tenant",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "propertyId": { "type": "string" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Message",
      "description": "Individual chat message",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "User's favorite property",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "propertyId"]
    }
  },
  "firestore": {
    "users/{userId}": { "schema": "User", "description": "User profiles" },
    "properties/{propertyId}": { "schema": "Property", "description": "Property listings" },
    "chats/{chatId}": { "schema": "Chat", "description": "Chat sessions" },
    "chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Messages within a chat" },
    "users/{userId}/favorites/{favoriteId}": { "schema": "Favorite", "description": "User favorites" }
  }
}
